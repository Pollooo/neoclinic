{
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "target": "frontend",
    "public": "NeoClinic/NeoClinic.Web/dist/NeoClinic.Web/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
